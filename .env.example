# Copy to .env and fill in values:
#   cp .env.example .env

# --- Agent (required) ---
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
# Optional: cheaper/faster model for explorer subagent (defaults to OPENAI_MODEL)
# OPENAI_EXPLORER_MODEL=gpt-4o-mini
# Optional: stronger model for executor subagent (defaults to OPENAI_MODEL)
# OPENAI_EXECUTOR_MODEL=gpt-4o
# Optional: improve OpenAI prompt-cache hit routing (same key across agent steps)
# OPENAI_PROMPT_CACHE_KEY=coding-agent-harness
# OPENAI_PROMPT_CACHE_RETENTION=in_memory   # or 24h on supported models (gpt-4.1 / gpt-5.x)

# --- Sandbox backend ---
# local (default) | cloud
SANDBOX=local

# --- Cloud sandbox (only when SANDBOX=cloud) ---
# Repo cloned into the VM at startup (must be on GitHub/GitLab, not local disk)
CLOUD_GIT_URL=https://github.com/your-user/your-repo.git
# Optional: branch, tag, or commit SHA (default: repo default branch)
# CLOUD_GIT_REVISION=main

# Optional: restore from a previous VM snapshot instead of git clone
# VERCEL_SNAPSHOT_ID=

# --- Vercel auth — pick one method ---
# (local dev): run `vercel link` then `vercel env pull .env.local`
# and copy VERCEL_OIDC_TOKEN into .env (expires ~12h; re-pull when auth fails)
# VERCEL_OIDC_TOKEN=

