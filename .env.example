# --- Agent ---
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_EXPLORER_MODEL=gpt-4o-mini
# OPENAI_EXECUTOR_MODEL=gpt-4o
# OPENAI_PROMPT_CACHE_KEY=coding-agent-harness
# OPENAI_PROMPT_CACHE_RETENTION=in_memory

# --- Craftly web (defaults to monorepo root) ---
# AGENT_CWD=/absolute/path/to/repo
 
# --- Sandbox (local | cloud) ---
SANDBOX=local

# --- Cloud (SANDBOX=cloud) ---
CLOUD_GIT_URL=https://github.com/your-user/your-repo.git
# CLOUD_GIT_REVISION=main
# VERCEL_SNAPSHOT_ID=
# VERCEL_OIDC_TOKEN=
